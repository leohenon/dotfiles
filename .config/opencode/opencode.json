                  "thinkingBudget": 16000,
                  "includeThoughts": true
                }
              }
            },
            "high": {
              "options": {
                "thinkingConfig": {
                  "thinkingBudget": 32000,
                  "includeThoughts": true
                }
              }
            }
          }
        },
        "gemini-claude-opus-4-6-thinking": {
          "id": "gemini-claude-opus-4-6-thinking",
          "name": "Claude Opus 4.6",
          "release_date": "2026-02-05",
          "reasoning": true,
          "limit": {
            "context": 200000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "none": {
              "reasoning": false,
              "options": {
                "thinkingConfig": {
                  "includeThoughts": false
                }
              }
            },
            "low": {
              "options": {
                "thinkingConfig": {
                  "thinkingBudget": 4000,
                  "includeThoughts": true
                }
              }
            },
            "medium": {
              "options": {
                "thinkingConfig": {
                  "thinkingBudget": 16000,
                  "includeThoughts": true
                }
              }
            },
            "high": {
              "options": {
                "thinkingConfig": {
                  "thinkingBudget": 32000,
                  "includeThoughts": true
                }
              }
            },
            "max": {
              "options": {
                "thinkingConfig": {
                  "thinkingBudget": 64000,
                  "includeThoughts": true
                }
              }
            }
          }
        },
        "gemini-claude-opus-4-5-thinking": {
          "id": "gemini-claude-opus-4-5-thinking",
          "name": "Claude Opus 4.5",
          "release_date": "2025-11-24",
          "reasoning": true,
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "options": {
                "thinkingConfig": {
                  "thinkingBudget": 4000,
                  "includeThoughts": true
                }
              }
            },
            "medium": {
